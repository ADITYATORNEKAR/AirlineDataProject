# ─────────────────────────────────────────────
# BLOCK 3: Outlier Handling
# ─────────────────────────────────────────────
# MMA accounts have fat tails — large rate-driven
# inflows/outflows. Flag and clip before feature eng.

def flag_and_clip_outliers(df: pd.DataFrame, sigma: float = 4.0) -> pd.DataFrame:
    """
    Per-account outlier detection on daily balance CHANGE (not level).
    Clips extreme 1-day moves to ±sigma standard deviations.
    Adds binary flag column so model can learn outlier regime.
    """
    df = df.sort_values([CONFIG['account_col'], CONFIG['date_col']]).copy()

    df['balance_change_1d'] = (
        df.groupby(CONFIG['account_col'])[CONFIG['balance_col']]
        .diff()
    )

    # Per-account stats
    stats = (
        df.groupby(CONFIG['account_col'])['balance_change_1d']
        .agg(['mean', 'std'])
        .rename(columns={'mean': 'chg_mean', 'std': 'chg_std'})
        .reset_index()
    )
    df = df.merge(stats, on=CONFIG['account_col'], how='left')

    upper = df['chg_mean'] + sigma * df['chg_std']
    lower = df['chg_mean'] - sigma * df['chg_std']

    df['is_outlier_day'] = (
        (df['balance_change_1d'] > upper) |
        (df['balance_change_1d'] < lower)
    ).astype(int)

    # Clip the balance series itself
    # Reconstruct clipped balance from clipped changes
    df['balance_change_1d_clipped'] = df['balance_change_1d'].clip(lower=lower, upper=upper)

    logger.info(
        f"Outlier days flagged: {df['is_outlier_day'].sum():,} "
        f"({df['is_outlier_day'].mean()*100:.2f}% of rows)"
    )

    df = df.drop(columns=['chg_mean', 'chg_std'])
    return df

