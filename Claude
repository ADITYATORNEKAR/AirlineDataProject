def load_and_validate(filepath: str) -> pd.DataFrame:
    """
    Load raw daily balance data, validate schema, filter to MMA.
    
    Expected schema:
        date          : YYYY-MM-DD
        account_id    : str/int unique account identifier
        customer_id   : str/int customer (one customer → many accounts)
        product_type  : CHK | MMA | SAV | CD
        balance       : float, end-of-day balance in USD
    """
    df = pd.read_parquet(filepath)  # swap to pd.read_csv() if needed

    # ── Schema check ───────────────────────────────────────────────────────────
    required_cols = [
        CONFIG['date_col'], CONFIG['account_col'],
        CONFIG['customer_col'], CONFIG['balance_col'],
        CONFIG['product_col']
    ]
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(f"Missing columns: {missing}")

    # ── Type coercion ──────────────────────────────────────────────────────────
    df[CONFIG['date_col']]    = pd.to_datetime(df[CONFIG['date_col']])
    df[CONFIG['balance_col']] = df[CONFIG['balance_col']].astype(float)
    df[CONFIG['account_col']] = df[CONFIG['account_col']].astype(str)
    df[CONFIG['customer_col']]= df[CONFIG['customer_col']].astype(str)

    # ── Filter to MMA only ─────────────────────────────────────────────────────
    df = df[df[CONFIG['product_col']] == CONFIG['product_filter']].copy()
    logger.info(f"MMA accounts loaded: {df[CONFIG['account_col']].nunique():,}")
    logger.info(f"Date range: {df[CONFIG['date_col']].min()} → {df[CONFIG['date_col']].max()}")
    logger.info(f"Total rows: {len(df):,}")

    # ── Integrity checks ───────────────────────────────────────────────────────
    dupes = df.duplicated(subset=[CONFIG['date_col'], CONFIG['account_col']]).sum()
    if dupes > 0:
        logger.warning(f"{dupes} duplicate (date, account) rows — keeping last")
        df = df.drop_duplicates(
            subset=[CONFIG['date_col'], CONFIG['account_col']], keep='last'
        )

    # ── Ensure contiguous daily index per account ──────────────────────────────
    # Fill missing dates with NaN balance (handled in feature eng)
    df = df.set_index([CONFIG['account_col'], CONFIG['date_col']])
    full_idx = pd.MultiIndex.from_product(
        [df.index.get_level_values(0).unique(),
         pd.date_range(df.index.get_level_values(1).min(),
                       df.index.get_level_values(1).max(), freq='D')],
        names=[CONFIG['account_col'], CONFIG['date_col']]
    )
    df = df.reindex(full_idx)
    df[CONFIG['balance_col']] = (
        df[CONFIG['balance_col']]
        .groupby(level=0)
        .transform(lambda s: s.ffill().bfill())   # forward-fill gaps
    )
    df = df.reset_index()

    # ── Negative balance guard ─────────────────────────────────────────────────
    neg = (df[CONFIG['balance_col']] < 0).sum()
    if neg > 0:
        logger.warning(f"{neg} negative balance rows — clipping to 0")
        df[CONFIG['balance_col']] = df[CONFIG['balance_col']].clip(lower=0)

    return df.sort_values([CONFIG['account_col'], CONFIG['date_col']]).reset_index(drop=True)


# ── Account-level summary (used downstream) ────────────────────────────────────
def account_summary(df: pd.DataFrame) -> pd.DataFrame:
    """Per-account metadata computed from history — used as static features."""
    grp = df.groupby(CONFIG['account_col'])[CONFIG['balance_col']]
    summary = pd.DataFrame({
        'avg_balance'         : grp.mean(),
        'std_balance'         : grp.std(),
        'min_balance'         : grp.min(),
        'max_balance'         : grp.max(),
        'cv_balance'          : grp.std() / (grp.mean() + 1),   # coefficient of variation
        'account_tenure_days' : df.groupby(CONFIG['account_col'])[CONFIG['date_col']].count(),
        'customer_id'         : df.groupby(CONFIG['account_col'])[CONFIG['customer_col']].first(),
    }).reset_index()
    return summary

