def build_lag_features(df: pd.DataFrame) -> pd.DataFrame:
    """Lag + rolling features. Computed from historical balance only."""
    df = df.sort_values([CONFIG['account_col'], CONFIG['date_col']]).copy()
    bal = CONFIG['balance_col']
    grp = df.groupby(CONFIG['account_col'])[bal]

    # ── Lag features ──────────────────────────────────────────────────────────
    for lag in [1, 7, 14, 30, 60, 90]:
        df[f'lag_{lag}'] = grp.shift(lag)

    # ── Rolling statistics ─────────────────────────────────────────────────────
    for window in [7, 30, 90]:
        rolled = grp.shift(1).transform(
            lambda s: s.rolling(window, min_periods=max(1, window // 2))
        )
        df[f'roll_mean_{window}'] = rolled.mean() if hasattr(rolled, 'mean') else \
            grp.shift(1).transform(lambda s: s.rolling(window, min_periods=1).mean())
        df[f'roll_std_{window}']  = grp.shift(1).transform(
            lambda s: s.rolling(window, min_periods=1).std().fillna(0)
        )

    # Cleaner rolling calculation (more explicit):
    for window in [7, 30, 90]:
        df[f'roll_mean_{window}'] = grp.shift(1).transform(
            lambda s: s.rolling(window, min_periods=1).mean()
        )
        df[f'roll_std_{window}'] = grp.shift(1).transform(
            lambda s: s.rolling(window, min_periods=1).std().fillna(0)
        )
        df[f'roll_min_{window}'] = grp.shift(1).transform(
            lambda s: s.rolling(window, min_periods=1).min()
        )
        df[f'roll_max_{window}'] = grp.shift(1).transform(
            lambda s: s.rolling(window, min_periods=1).max()
        )

    # ── Momentum / change features ─────────────────────────────────────────────
    df['chg_1d']         = grp.diff(1)
    df['chg_7d']         = grp.diff(7)
    df['chg_30d']        = grp.diff(30)
    df['pct_chg_30d']    = grp.pct_change(30).replace([np.inf, -np.inf], np.nan)
    df['bal_vs_90d_avg'] = df[bal] - df['roll_mean_90']   # deviation from quarterly mean

    return df


def build_calendar_features(df: pd.DataFrame) -> pd.DataFrame:
    """Calendar features — all known at prediction time, zero leakage."""
    d = df[CONFIG['date_col']]

    df['day_of_week']    = d.dt.dayofweek          # 0=Mon
    df['day_of_month']   = d.dt.day
    df['day_of_year']    = d.dt.dayofyear
    df['week_of_year']   = d.dt.isocalendar().week.astype(int)
    df['month']          = d.dt.month
    df['quarter']        = d.dt.quarter
    df['is_month_start'] = (d.dt.day <= 3).astype(int)
    df['is_month_end']   = (d.dt.day >= d.dt.days_in_month - 2).astype(int)
    df['is_quarter_end'] = (
        (d.dt.month.isin([3, 6, 9, 12])) & (d.dt.day >= 28)
    ).astype(int)
    df['is_year_end']    = (
        (d.dt.month == 12) & (d.dt.day >= 28)
    ).astype(int)
    df['is_weekend']     = (d.dt.dayofweek >= 5).astype(int)

    # US Federal holidays (static list — expand as needed)
    us_holidays = pd.to_datetime([
        '2023-01-02', '2023-01-16', '2023-02-20', '2023-05-29',
        '2023-06-19', '2023-07-04', '2023-09-04', '2023-10-09',
        '2023-11-10', '2023-11-23', '2023-12-25',
        '2024-01-01', '2024-01-15', '2024-02-19', '2024-05-27',
        '2024-06-19', '2024-07-04', '2024-09-02', '2024-10-14',
        '2024-11-11', '2024-11-28', '2024-12-25',
        '2025-01-01', '2025-01-20', '2025-02-17', '2025-05-26',
        '2025-06-19', '2025-07-04', '2025-09-01', '2025-10-13',
        '2025-11-11', '2025-11-27', '2025-12-25',
    ])
    df['is_holiday'] = d.isin(us_holidays).astype(int)

    # Days-to/from key dates (MMA rate decisions often land mid-month)
    df['days_to_month_end'] = d.dt.days_in_month - d.dt.day
    df['days_since_month_start'] = d.dt.day - 1

    return df


def build_customer_cross_product_features(
    full_df: pd.DataFrame,          # ALL products (CHK+MMA+SAV+CD)
    mma_df: pd.DataFrame,           # MMA only
    as_of_dates: pd.Series = None   # if None, use each row's date
) -> pd.DataFrame:
    """
    Customer-level aggregates across ALL products — flows down to every MMA account row.
    All computed from historical data as-of each row's date (no leakage).
    
    NOTE: full_df must contain all products for the same customers.
    """
    logger.info("Building cross-product customer features...")

    # Compute customer-level balance snapshots per date
    cust_daily = (
        full_df
        .groupby([CONFIG['customer_col'], CONFIG['date_col'], CONFIG['product_col']])[CONFIG['balance_col']]
        .sum()
        .unstack(fill_value=0)
        .reset_index()
    )

    # Ensure all product columns exist (customer may not have all products)
    for p in ['CHK', 'MMA', 'SAV', 'CD']:
        if p not in cust_daily.columns:
            cust_daily[p] = 0.0

    cust_daily['total_balance']   = cust_daily[['CHK', 'MMA', 'SAV', 'CD']].sum(axis=1)
    cust_daily['liquid_balance']  = cust_daily['CHK'] + cust_daily['SAV']
    cust_daily['mma_share']       = cust_daily['MMA'] / (cust_daily['total_balance'] + 1)
    cust_daily['liquid_ratio']    = cust_daily['liquid_balance'] / (cust_daily['total_balance'] + 1)
    cust_daily['num_products']    = (cust_daily[['CHK', 'MMA', 'SAV', 'CD']] > 0).sum(axis=1)

    # 30d rolling net flow per customer (directional signal — drawing down or building?)
    cust_daily = cust_daily.sort_values([CONFIG['customer_col'], CONFIG['date_col']])
    cust_daily['cust_total_30d_net_flow'] = (
        cust_daily.groupby(CONFIG['customer_col'])['total_balance']
        .transform(lambda s: s.diff(30))
    )

    # MMA-specific: 30d net flow into MMA (rate chasing behavior)
    cust_daily['cust_mma_30d_net_flow'] = (
        cust_daily.groupby(CONFIG['customer_col'])['MMA']
        .transform(lambda s: s.diff(30))
    )

    keep_cols = [
        CONFIG['customer_col'], CONFIG['date_col'],
        'total_balance', 'liquid_balance', 'mma_share',
        'liquid_ratio', 'num_products',
        'cust_total_30d_net_flow', 'cust_mma_30d_net_flow'
    ]
    cust_features = cust_daily[keep_cols]

    # Join to MMA account rows
    mma_df = mma_df.merge(cust_features, on=[CONFIG['customer_col'], CONFIG['date_col']], how='left')
    return mma_df


def assemble_features(
    df: pd.DataFrame,
    stl_features: pd.DataFrame,
    account_summary_df: pd.DataFrame,
    full_df: pd.DataFrame,          # all products for cross-product features
) -> pd.DataFrame:
    """Master feature assembly — joins all feature blocks."""

    df = build_lag_features(df)
    df = build_calendar_features(df)
    df = build_customer_cross_product_features(full_df, df)

    # Join STL features (one row per account — broadcast to all dates)
    df = df.merge(stl_features, on=CONFIG['account_col'], how='left')

    # Join account summary metadata
    df = df.merge(
        account_summary_df[[CONFIG['account_col'], 'avg_balance', 'std_balance',
                             'cv_balance', 'account_tenure_days']],
        on=CONFIG['account_col'], how='left'
    )

    # Account tenure buckets (categorical)
    df['tenure_bucket'] = pd.cut(
        df['account_tenure_days'],
        bins=[0, 90, 365, 730, np.inf],
        labels=['new', 'young', 'mature', 'veteran']
    ).astype(str)

    logger.info(f"Feature matrix shape: {df.shape}")
    return df

