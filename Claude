def build_account_summary(df: pd.DataFrame) -> pd.DataFrame:
    """
    Per-account static stats from full history.
    Used for: segment assignment + LightGBM metadata features.
    """
    grp = df.groupby('account_id')['balance']

    summary = pd.DataFrame({
        'avg_balance'         : grp.mean(),
        'std_balance'         : grp.std().fillna(0),
        'min_balance'         : grp.min(),
        'max_balance'         : grp.max(),
        'account_tenure_days' : df.groupby('account_id')['date'].count(),
        'customer_id'         : df.groupby('account_id')['customer_id'].first(),
    }).reset_index()

    summary['cv_balance'] = summary['std_balance'] / (summary['avg_balance'] + 1)

    # ── Rule-based segment (no KMeans at runtime) ──────────────────────────────
    summary['segment_id'] = assign_segments_vectorized(summary)

    seg_dist = summary['segment_id'].value_counts().sort_index()
    neg_accts = (summary['avg_balance'] < 0).sum()
    if neg_accts > 0:
        logger.warning(
            f"{neg_accts:,} accounts with negative avg_balance → seg 0. "
            f"Review for fee postings / pipeline timing issues."
        )
    logger.info("Segment distribution:")
    for sid, n in seg_dist.items():
        label = SEGMENT_LABELS.get(sid, '?')
        logger.info(f"  Seg {sid} ({label:25s}): {n:,} accounts")

    return summary


