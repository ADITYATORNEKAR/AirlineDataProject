# =============================================================================
# Pure balance-tier segmentation — no KMeans deployed or imported.
# Segments assigned using avg_balance computed from account history.
#
# HOW TO UPDATE: Edit BALANCE_TIERS thresholds below only.
#                No model refit needed — just update and redeploy.
#
# Segment map:
#   seg 0 — Negative          : avg_balance < 0
#                               Rare in MMA (no standard overdraft feature).
#                               Can occur via fee deductions on near-zero
#                               accounts, timing gaps between debit/credit
#                               settlement, or manual adjustment postings.
#                               More common in CHK. Still modeled separately
#                               here — do NOT mix with seg 1. MAPE will be
#                               unreliable for this segment; flag for ops review
#                               and consider excluding from liquidity reporting.
#   seg 1 — Micro             : $0        to $10K
#   seg 2 — Small             : $10K      to $25K
#   seg 3 — Mid               : $25K      to $125K
#   seg 4 — Upper Mid         : $125K     to $500K
#   seg 5 — High              : $500K     to $1M
#   seg 6 — Very High         : $1M       to $5M
#   seg 7 — Ultra High        : above $5M  (institutional / wealth mgmt)
# =============================================================================

# Edit thresholds here — segment IDs and labels auto-update everywhere downstream
#
# DESIGN RATIONALE (from ED&A findings):
#
#   Post-25K stability gradient:
#       MMA accounts become progressively more stable as balance grows above $25K.
#       Tier widths increase with balance size to reflect this — narrower splits
#       where volatility is high, wider splits where behavior homogenizes.
#
#   125K–500K split into two (was one bucket):
#       ED&A shows >50% MoM% change AND highest account concentration here.
#       This bucket was masking two distinct behaviors:
#           125K–250K : rate-chasers, frequent movers, high transfer velocity
#           250K–500K : transitioning toward stability, less frequent moves
#       Splitting gives each its own LightGBM — critical for MAPE in this range.
#
#   1M–5M kept as one but flagged:
#       Second highest account count per ED&A. Likely contains business/
#       institutional MMA accounts with different seasonality and transfer
#       patterns vs retail. If MoM% volatility analysis shows similar
#       heterogeneity inside this bucket, consider splitting at $2.5M.
#
#   Stability gradient summary:
#       <25K    : volatile, frequent small moves
#       25–125K : moderate, beginning to stabilize
#       125–250K: volatile peak (rate-chasing behavior dominates)
#       250–500K: transitioning, mix of behaviors
#       500K–1M : stable, mostly parking / wealth management
#       1M–5M   : stable but high-value, some institutional behavior
#       5M+     : ultra stable, very low frequency large moves

BALANCE_TIERS = [
    # (segment_id, label,                  avg_bal_min,    avg_bal_max)
    ( 0,  'negative',                          -np.inf,             0),
    ( 1,  'micro_0_10k',                             0,        10_000),
    ( 2,  'small_10k_25k',                      10_000,        25_000),
    ( 3,  'mid_25k_125k',                        25_000,       125_000),  # stable gradient begins
    ( 4,  'upper_mid_125k_250k',                125_000,       250_000),  # SPLIT: rate-chasing volatile tier
    ( 5,  'upper_mid_250k_500k',                250_000,       500_000),  # SPLIT: transitioning to stable
    ( 6,  'high_500k_1m',                       500_000,     1_000_000),  # stable, wealth parking
    ( 7,  'very_high_1m_5m',                  1_000_000,     5_000_000),  # high count, watch for biz accounts
    ( 8,  'ultra_high_5m_plus',               5_000_000,        np.inf),  # ultra stable, low frequency
]

N_SEGMENTS     = len(BALANCE_TIERS)
