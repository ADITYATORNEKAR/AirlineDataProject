# ─────────────────────────────────────────────
# BLOCK 12: Inference — 90-Day Daily Forecast
# Predict at anchor horizons, interpolate between.
# ─────────────────────────────────────────────

def generate_forecast(
    df: pd.DataFrame,
    model_registry: dict,
    as_of_date: str,
) -> pd.DataFrame:
    """
    Generate 90-day daily balance forecast for all MMA accounts.
    
    Args:
        df           : full feature-engineered DataFrame
        model_registry: {(cluster_id, horizon): lgb.Booster}
        as_of_date   : forecast origin date (YYYY-MM-DD string)
    
    Returns:
        DataFrame with columns:
            account_id, customer_id, forecast_date, days_ahead, balance_forecast
    """
    as_of_date = pd.to_datetime(as_of_date)

    # ── Snap to as_of_date ─────────────────────────────────────────────────────
    snap = df[df[CONFIG['date_col']] == as_of_date].copy()
    if len(snap) == 0:
        raise ValueError(f"No data found for as_of_date={as_of_date}")

    logger.info(f"Generating forecasts for {len(snap):,} MMA accounts as of {as_of_date.date()}")

    # ── Predict at anchor horizons ─────────────────────────────────────────────
    anchor_predictions = {}    # account_id → {h: pred}

    for (cluster_id, horizon), model in model_registry.items():
        cluster_snap = snap[snap['behavior_cluster'] == cluster_id]
        valid_snap   = cluster_snap.dropna(subset=FEATURE_COLS)

        if len(valid_snap) == 0:
            continue

        preds = model.predict(valid_snap[FEATURE_COLS])
        preds = np.maximum(preds, 0)   # no negative balance predictions

        for account_id, pred in zip(valid_snap[CONFIG['account_col']].values, preds):
            if account_id not in anchor_predictions:
                anchor_predictions[account_id] = {}
            anchor_predictions[account_id][horizon] = pred

    # ── Interpolate to daily for days 1–90 ────────────────────────────────────
    forecast_rows = []
    anchors = CONFIG['anchor_horizons']

    for account_id, preds_by_horizon in anchor_predictions.items():
        account_row = snap[snap[CONFIG['account_col']] == account_id].iloc[0]
        customer_id = account_row[CONFIG['customer_col']]
        current_bal = account_row[CONFIG['balance_col']]

        # Build anchor arrays (include h=0 = current balance)
        h_vals  = [0] + [h for h in anchors if h in preds_by_horizon]
        y_vals  = [current_bal] + [preds_by_horizon[h] for h in anchors if h in preds_by_horizon]

        if len(h_vals) < 2:
            continue

        # Cubic spline interpolation between anchors
        from scipy.interpolate import interp1d
        interp_fn = interp1d(h_vals, y_vals, kind='cubic', fill_value='extrapolate')

        for day in range(1, CONFIG['max_horizon'] + 1):
            forecast_date = as_of_date + pd.Timedelta(days=day)
            balance_forecast = float(np.maximum(interp_fn(day), 0))

            forecast_rows.append({
                'account_id'       : account_id,
                'customer_id'      : customer_id,
                'as_of_date'       : as_of_date.date(),
                'forecast_date'    : forecast_date.date(),
                'days_ahead'       : day,
                'balance_forecast' : round(balance_forecast, 2),
            })

    forecast_df = pd.DataFrame(forecast_rows)
    logger.info(f"Forecast rows generated: {len(forecast_df):,}")

    # ── Portfolio-level summary ────────────────────────────────────────────────
    portfolio_summary = (
        forecast_df.groupby('days_ahead')['balance_forecast']
        .sum()
        .reset_index()
        .rename(columns={'balance_forecast': 'portfolio_total_mma'})
    )
    logger.info(f"\nPortfolio MMA Balance (as of {as_of_date.date()}):")
    for _, row in portfolio_summary[portfolio_summary['days_ahead'].isin([1,30,60,90])].iterrows():
        logger.info(f"  Day {int(row['days_ahead']):3d}: ${row['portfolio_total_mma']:,.0f}")

    return forecast_df, portfolio_summary

