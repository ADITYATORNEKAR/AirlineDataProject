    return {
        'model_registry'  : model_registry,
        'param_registry'  : param_registry,
        'forecast_df'     : forecast_df,
        'portfolio_df'    : portfolio_df,
        'eval_df'         : eval_df,
        'kmeans'          : kmeans_model,
        'scaler'          : scaler_model,
