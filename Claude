# ─────────────────────────────────────────────
# BLOCK 6: Account Behavior Clustering
# ─────────────────────────────────────────────
# Clusters MMA accounts by behavior archetype.
# Each cluster gets its own LightGBM — better accuracy,
# faster tuning, scales cleanly to new channels.

CLUSTER_FEATURES = [
    'avg_balance', 'cv_balance',        # size + volatility
    'slope_90d_norm',                   # long-run trend direction
    'seasonal_strength',                # how seasonal is this account?
    'trend_strength',                   # trending vs mean-reverting
    'residual_std_norm',                # idiosyncratic shock frequency
    'account_tenure_days',              # account age
]

def fit_clusters(account_summary_df: pd.DataFrame, stl_features: pd.DataFrame) -> tuple:
    """
    Fit KMeans clusters on MMA account behavior profiles.
    Returns (cluster_labels_df, fitted_kmeans, fitted_scaler)
    """
    cluster_input = account_summary_df.merge(stl_features, on=CONFIG['account_col'], how='left')
    X = cluster_input[CLUSTER_FEATURES].fillna(0)

    scaler  = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    kmeans = KMeans(
        n_clusters=CONFIG['n_clusters'],
        random_state=42,
        n_init=10,
        max_iter=300
    )
    cluster_input['behavior_cluster'] = kmeans.fit_predict(X_scaled)

    logger.info("Cluster distribution (MMA accounts):")
    dist = cluster_input['behavior_cluster'].value_counts().sort_index()
    for c, n in dist.items():
        logger.info(f"  Cluster {c:2d}: {n:,} accounts")

    return (
        cluster_input[[CONFIG['account_col'], 'behavior_cluster']],
        kmeans,
        scaler
    )


def assign_clusters(
    account_summary_df: pd.DataFrame,
    stl_features: pd.DataFrame,
    kmeans: KMeans,
    scaler: StandardScaler
) -> pd.DataFrame:
    """Assign clusters to new accounts using fitted kmeans/scaler."""
    cluster_input = account_summary_df.merge(stl_features, on=CONFIG['account_col'], how='left')
    X = cluster_input[CLUSTER_FEATURES].fillna(0)
    X_scaled = scaler.transform(X)
    cluster_input['behavior_cluster'] = kmeans.predict(X_scaled)
    return cluster_input[[CONFIG['account_col'], 'behavior_cluster']]

