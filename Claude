# ─────────────────────────────────────────────
# BLOCK 4: STL Decomposition — Parallel
# ─────────────────────────────────────────────
# Replaces Prophet for speed. Runs STL per account,
# extracts slope at multiple horizons + seasonal pattern.
# All features computed from HISTORICAL data only — no leakage.

def _stl_single_account(args) -> dict:
    """Worker function — runs in subprocess via ProcessPoolExecutor."""
    account_id, series, horizon = args

    result = {
        'account_id'         : account_id,
        'slope_14d_norm'     : np.nan,
        'slope_30d_norm'     : np.nan,
        'slope_90d_norm'     : np.nan,
        'slope_acceleration' : np.nan,
        'seasonal_strength'  : np.nan,
        'trend_strength'     : np.nan,
        'residual_std_norm'  : np.nan,
        'seasonal_at_h30'    : np.nan,
        'seasonal_at_h60'    : np.nan,
        'seasonal_at_h90'    : np.nan,
    }

    try:
        if len(series) < 30:          # skip accounts with too little history
            return result

        avg_bal = series.mean() + 1   # denominator guard

        stl = STL(series, period=CONFIG['stl_period'], robust=CONFIG['stl_robust'])
        fit = stl.fit()

        trend    = fit.trend
        seasonal = fit.seasonal
        resid    = fit.resid

        # ── Slopes (linear fit on trend component) ─────────────────────────────
        n = len(trend)
        x = np.arange(n)

        # Slope over last 14, 30, 90 days of history
        def _slope(window):
            w = min(window, n)
            xi = x[-w:]
            yi = trend[-w:]
            return np.polyfit(xi, yi, 1)[0]  # coefficient of day

        s14 = _slope(14)
        s30 = _slope(30)
        s90 = _slope(min(90, n))

        result['slope_14d_norm']     = s14 / avg_bal
        result['slope_30d_norm']     = s30 / avg_bal
        result['slope_90d_norm']     = s90 / avg_bal
        result['slope_acceleration'] = (s14 - s90) / avg_bal   # positive = speeding up

        # ── Seasonal strength (ratio of seasonal variance to total) ────────────
        var_total    = np.var(series)
        var_resid    = np.var(resid)
        var_seasonal = np.var(seasonal)
        var_trend    = np.var(trend)

        result['seasonal_strength'] = var_seasonal / (var_total + 1e-10)
        result['trend_strength']    = var_trend    / (var_total + 1e-10)
        result['residual_std_norm'] = np.std(resid) / avg_bal

        # ── Projected seasonal value at future horizons ────────────────────────
        # Use last full seasonal cycle (7 days) as proxy for next cycle
        # MMA weekly seasonal pattern is stable enough for this
        cycle = seasonal[-CONFIG['stl_period']:].values

        def _seasonal_at(h):
            idx = (h - 1) % CONFIG['stl_period']
            return cycle[idx] / avg_bal

        result['seasonal_at_h30'] = _seasonal_at(30)
        result['seasonal_at_h60'] = _seasonal_at(60)
        result['seasonal_at_h90'] = _seasonal_at(90)

    except Exception as e:
        logger.debug(f"STL failed for account {account_id}: {e}")

    return result


def run_stl_parallel(df: pd.DataFrame) -> pd.DataFrame:
    """
    Run STL on all MMA accounts in parallel.
    Returns a DataFrame with one row per account_id — slope features.
    """
    accounts = []
    for account_id, grp in df.groupby(CONFIG['account_col']):
        series = (
            grp.sort_values(CONFIG['date_col'])
            [CONFIG['balance_col']]
            .values
        )
        accounts.append((account_id, series, CONFIG['max_horizon']))

    logger.info(f"Running STL on {len(accounts):,} MMA accounts with {CONFIG['n_workers']} workers...")

    with ProcessPoolExecutor(max_workers=CONFIG['n_workers']) as executor:
        results = list(executor.map(_stl_single_account, accounts))

    stl_features = pd.DataFrame(results)
    logger.info(f"STL complete. NaN rate: {stl_features.isna().mean().mean()*100:.1f}%")
    return stl_features

