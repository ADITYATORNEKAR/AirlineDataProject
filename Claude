def build_targets(df: pd.DataFrame) -> pd.DataFrame:
    """
    For each anchor horizon h, add a target column:
        target_h{h} = balance h days in the future
    
    Rows where target falls outside history are NaN (excluded at training time).
    Walk-forward split must ensure no future leakage.
    """
    df = df.sort_values([CONFIG['account_col'], CONFIG['date_col']]).copy()
    grp = df.groupby(CONFIG['account_col'])[CONFIG['balance_col']]

    for h in CONFIG['anchor_horizons']:
        df[f'target_h{h}'] = grp.shift(-h)   # shift back = look forward
        logger.info(f"  target_h{h}: {df[f'target_h{h}'].notna().sum():,} valid rows")

    return df


FEATURE_COLS = [
    # Lag features
    'lag_1', 'lag_7', 'lag_14', 'lag_30', 'lag_60', 'lag_90',
    # Rolling
    'roll_mean_7', 'roll_mean_30', 'roll_mean_90',
    'roll_std_7', 'roll_std_30', 'roll_std_90',
    'roll_min_30', 'roll_max_30', 'roll_min_90', 'roll_max_90',
    # Momentum
    'chg_1d', 'chg_7d', 'chg_30d', 'pct_chg_30d', 'bal_vs_90d_avg',
    'balance_change_1d', 'is_outlier_day',
    # Calendar
    'day_of_week', 'day_of_month', 'day_of_year', 'week_of_year',
