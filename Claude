def _prophet_worker(args: tuple) -> dict:
    """
    Subprocess worker — fits Prophet on one account.
    Returns dict of leakage-free slope + seasonality features.
    Speed levers applied:
        - uncertainty_samples=100 (10x faster than default 1000)
        - MAP estimation (no MCMC — 50x faster)
        - daily_seasonality=False
        - n_changepoints=15 (vs default 25)
        - Stan/Prophet logging suppressed
    """
    account_id, balance_vals, dates, cfg = args

    result = {
        'account_id'              : account_id,
        'slope_14d_norm'          : np.nan,
        'slope_30d_norm'          : np.nan,
        'slope_90d_norm'          : np.nan,
        'slope_acceleration'      : np.nan,
        'prophet_uncertainty_pct' : np.nan,
        'seasonal_at_h30'         : np.nan,
        'seasonal_at_h60'         : np.nan,
        'seasonal_at_h90'         : np.nan,
        'prophet_trend_at_h90'    : np.nan,
        'prophet_success'         : False,
    }

    if len(balance_vals) < 30:
        return result

    try:
        # ── Silence Prophet / Stan output ─────────────────────────────────────
        import logging as _log
        _log.getLogger('prophet').setLevel(_log.ERROR)
        _log.getLogger('cmdstanpy').setLevel(_log.ERROR)
        os.environ['CMDSTAN_QUIET'] = '1'

        from prophet import Prophet

        avg_bal = float(np.mean(balance_vals)) + 1.0

        prophet_df = pd.DataFrame({
            'ds': pd.to_datetime(dates),
            'y' : balance_vals.astype(float),
        })

        m = Prophet(
            changepoint_prior_scale = cfg['changepoint_prior_scale'],
            n_changepoints          = cfg['n_changepoints'],
            yearly_seasonality      = cfg['yearly_seasonality'],
            weekly_seasonality      = cfg['weekly_seasonality'],
            daily_seasonality       = cfg['daily_seasonality'],
            uncertainty_samples     = cfg['uncertainty_samples'],
        )

        # Redirect stdout to suppress Stan compile/sampling noise
        with open(os.devnull, 'w') as devnull:
            _old = sys.stdout
            sys.stdout = devnull
            try:
                m.fit(prophet_df)
            finally:
                sys.stdout = _old

        future   = m.make_future_dataframe(periods=cfg['forecast_horizon'], freq='D')
        forecast = m.predict(future)
        fcast    = forecast.tail(cfg['forecast_horizon']).reset_index(drop=True)

        # ── Slopes from trend component ────────────────────────────────────────
        trend = fcast['trend'].values

        def _slope(window):
            w = min(window, len(trend))
            return (trend[w - 1] - trend[0]) / (w * avg_bal)

        s14 = _slope(14)
        s30 = _slope(30)
        s90 = _slope(90)

        result['slope_14d_norm']     = s14
        result['slope_30d_norm']     = s30
        result['slope_90d_norm']     = s90
        result['slope_acceleration'] = s14 - s90   # positive = accelerating

        # ── Uncertainty width (volatility proxy) ───────────────────────────────
        unc = fcast['yhat_upper'].iloc[-1] - fcast['yhat_lower'].iloc[-1]
        result['prophet_uncertainty_pct'] = unc / avg_bal

        # ── Seasonal components at future horizons ─────────────────────────────
        if 'weekly' in fcast.columns:
            result['seasonal_at_h30'] = fcast['weekly'].iloc[29] / avg_bal
            result['seasonal_at_h60'] = fcast['weekly'].iloc[59] / avg_bal
            result['seasonal_at_h90'] = fcast['weekly'].iloc[89] / avg_bal

        result['prophet_trend_at_h90'] = trend[-1] / avg_bal
        result['prophet_success']      = True

    except Exception as e:
        pass   # silent fail — NaN features handled downstream

    return result


def run_prophet_parallel(
    df         : pd.DataFrame,
    n_workers  : int = None,
) -> pd.DataFrame:
    """
    Parallel Prophet across all MMA accounts.
    Returns one-row-per-account slope+seasonality feature DataFrame.

    Approx wall time (20K accounts):
        8  workers  →  ~2–3 hrs
        16 workers  →  ~1–1.5 hrs  (SageMaker ml.m5.4xlarge)
        32 workers  →  ~40–50 min  (SageMaker ml.m5.12xlarge)
    """
    n_workers = n_workers or CONFIG['n_workers']

    tasks = []
    for account_id, grp in df.groupby('account_id'):
        g = grp.sort_values('date')
        tasks.append((
            account_id,
            g['balance'].values,
            g['date'].values,
            PROPHET_CFG,
        ))

    total     = len(tasks)
    succeeded = 0
    results   = []

    logger.info(
        f"Prophet: {total:,} accounts | {n_workers} workers | "
        f"uncertainty_samples={PROPHET_CFG['uncertainty_samples']} | "
        f"n_changepoints={PROPHET_CFG['n_changepoints']}"
    )

    with ProcessPoolExecutor(max_workers=n_workers) as executor:
        futures = {executor.submit(_prophet_worker, t): t[0] for t in tasks}
        for i, future in enumerate(as_completed(futures), 1):
            res = future.result()
            results.append(res)
            if res['prophet_success']:
                succeeded += 1
            if i % 2000 == 0 or i == total:
                logger.info(f"  Prophet progress: {i:,}/{total:,} | ok={succeeded:,}")

    out = pd.DataFrame(results)
    logger.info(
        f"Prophet done — success rate: {succeeded/total*100:.1f}% ({succeeded:,}/{total:,})"
    )
    return out


