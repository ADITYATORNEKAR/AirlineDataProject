def assign_segment(avg_balance: float) -> int:
    """
    Scalar segment assignment for a single account.
    Use assign_segments_vectorized() for full DataFrames.
    """
    for seg_id, _, bal_min, bal_max in BALANCE_TIERS:
        if bal_min <= avg_balance < bal_max:
            return seg_id
    return 8   # fallback → ultra_high (handles exact 5M boundary)


def assign_segments_vectorized(df: pd.DataFrame) -> pd.Series:
    """
    Vectorized segment assignment for full DataFrame.
    Requires column: avg_balance.
    Returns Series of segment_id integers.

    Boundary rule: lower bound inclusive, upper bound exclusive.
    e.g. exactly $125,000 → seg 4 (upper_mid_125k_250k), not seg 3.
    Negative avg_balance → seg 0 (flagged, modeled separately).
    """
    conditions = [
        df['avg_balance'] <           0,
        (df['avg_balance'] >=         0) & (df['avg_balance'] <      10_000),
        (df['avg_balance'] >=    10_000) & (df['avg_balance'] <      25_000),
        (df['avg_balance'] >=    25_000) & (df['avg_balance'] <     125_000),
        (df['avg_balance'] >=   125_000) & (df['avg_balance'] <     250_000),  # rate-chasing volatile
        (df['avg_balance'] >=   250_000) & (df['avg_balance'] <     500_000),  # transitioning
        (df['avg_balance'] >=   500_000) & (df['avg_balance'] <   1_000_000),
        (df['avg_balance'] >= 1_000_000) & (df['avg_balance'] <   5_000_000),
        df['avg_balance'] >= 5_000_000,
    ]
    choices = [0, 1, 2, 3, 4, 5, 6, 7, 8]
    return np.select(conditions, choices, default=3)   # default → mid_25k_125k


