# ─────────────────────────────────────────────
# BLOCK 8: Walk-Forward CV Splits
# ─────────────────────────────────────────────

def walk_forward_splits(df: pd.DataFrame, n_folds: int = 4, val_window: int = 90):
    """
    Generator yielding (train_idx, val_idx) for walk-forward CV.
    
    Never leaks: val always comes AFTER train in time.
    Validation window = val_window days (matches max forecast horizon).
    
    Example with 730 days, 4 folds, 90-day val window:
        Fold 1: train [  1–460], val [461–550]
        Fold 2: train [  1–550], val [551–640]
        Fold 3: train [  1–640], val [641–730]
        Fold 4: train [  1–550], val [551–640]  ← overlapping intentional
    """
    dates = df[CONFIG['date_col']].sort_values().unique()
    n_dates = len(dates)
    
    # Work backwards from end of data
    val_end   = n_dates
    splits    = []

    for fold in range(n_folds):
        val_start  = val_end - val_window
        train_end  = val_start

        if train_end < val_window * 2:   # need at least 2x val window for training
            logger.warning(f"Fold {fold+1}: insufficient training data — skipping")
            break

        train_dates = dates[:train_end]
        val_dates   = dates[val_start:val_end]

        train_idx = df[df[CONFIG['date_col']].isin(train_dates)].index
        val_idx   = df[df[CONFIG['date_col']].isin(val_dates)].index

        splits.append((fold + 1, train_idx, val_idx))
        logger.info(
            f"Fold {fold+1}: "
            f"train {dates[0].strftime('%Y-%m-%d')} → {dates[train_end-1].strftime('%Y-%m-%d')} "
            f"| val {val_dates[0].strftime('%Y-%m-%d')} → {val_dates[-1].strftime('%Y-%m-%d')}"
        )

        val_end = val_start   # slide window back

    return splits[::-1]   # return chronological order

Block 9 — Hyperparameter Tuning (Optuna)


python
# ─────────────────────────────────────────────
# BLOCK 9: Hyperparameter Tuning — Optuna
# Tune on 10% sample, one fold, with pruning.
# Apply best params to all clusters.
# ─────────────────────────────────────────────

def tune_hyperparameters(
    df: pd.DataFrame,
    horizon: int,
    cluster_id: int,
    splits: list,
) -> dict:
    """
    Tune LightGBM hyperparameters for a given horizon + cluster.
    Uses 10% account sample and single (latest) fold only.
    """
    target_col = f'target_h{horizon}'

    # ── Sample accounts for tuning ─────────────────────────────────────────────
    sampled_accounts = (
        df['account_id']
        .drop_duplicates()
        .sample(frac=CONFIG['tune_sample_frac'], random_state=42)
    )
    df_sample = df[df['account_id'].isin(sampled_accounts)]

    # Use the LAST (most recent) fold only for tuning speed
    _, train_idx, val_idx = splits[-1]

    # Intersect with sample
    train_idx = train_idx.intersection(df_sample.index)
    val_idx   = val_idx.intersection(df_sample.index)

    train_df = df_sample.loc[train_idx].dropna(subset=[target_col] + FEATURE_COLS)
    val_df   = df_sample.loc[val_idx].dropna(subset=[target_col] + FEATURE_COLS)

    if len(train_df) < 100 or len(val_df) < 10:
        logger.warning(f"  Cluster {cluster_id} h{horizon}: insufficient data for tuning, using defaults")
        return _default_params()

    X_train, y_train = train_df[FEATURE_COLS], train_df[target_col]
    X_val,   y_val   = val_df[FEATURE_COLS],   val_df[target_col]

    dtrain = lgb.Dataset(X_train, label=y_train,
                         categorical_feature=CATEGORICAL_COLS, free_raw_data=False)
    dval   = lgb.Dataset(X_val,   label=y_val,   reference=dtrain,
                         categorical_feature=CATEGORICAL_COLS, free_raw_data=False)

    def objective(trial):
        params = {
            'objective'       : 'mape',
            'metric'          : 'mape',
            'verbosity'       : -1,
            'boosting_type'   : 'gbdt',
            'num_leaves'      : trial.suggest_int('num_leaves', 31, 256),
            'learning_rate'   : trial.suggest_float('learning_rate', 0.01, 0.3, log=True),
            'min_child_samples': trial.suggest_int('min_child_samples', 20, 200),
            'feature_fraction': trial.suggest_float('feature_fraction', 0.5, 1.0),
            'bagging_fraction': trial.suggest_float('bagging_fraction', 0.6, 1.0),
            'bagging_freq'    : trial.suggest_int('bagging_freq', 1, 7),
            'reg_alpha'       : trial.suggest_float('reg_alpha', 1e-8, 10.0, log=True),
            'reg_lambda'      : trial.suggest_float('reg_lambda', 1e-8, 10.0, log=True),
            'n_jobs'          : -1,
        }

        pruning_cb = LightGBMPruningCallback(trial, 'valid mape')

        model = lgb.train(
            params,
            dtrain,
            valid_sets=[dval],
            num_boost_round=500,
            callbacks=[
                pruning_cb,
                lgb.early_stopping(CONFIG['early_stopping_rounds'], verbose=False),
                lgb.log_evaluation(0),
            ]
        )
        return model.best_score['valid mape']['mape']

    study = optuna.create_study(
        direction='minimize',
        pruner=optuna.pruners.MedianPruner(n_warmup_steps=10),
        sampler=optuna.samplers.TPESampler(seed=42)
    )
    study.optimize(
        objective,
        n_trials=CONFIG['tune_n_trials'],
        timeout=CONFIG['tune_timeout_sec'],
        show_progress_bar=False
    )

    best = study.best_params
    best.update({'objective': 'mape', 'metric': 'mape',
                 'verbosity': -1, 'n_jobs': -1})
    logger.info(f"  Cluster {cluster_id} h{horizon}: best MAPE={study.best_value:.4f} | params={best}")
    return best


def _default_params() -> dict:
    return {
        'objective'        : 'mape',
        'metric'           : 'mape',
        'verbosity'        : -1,
        'num_leaves'       : 63,
        'learning_rate'    : 0.05,
        'min_child_samples': 50,
        'feature_fraction' : 0.8,
        'bagging_fraction' : 0.8,
        'bagging_freq'     : 5,
        'reg_alpha'        : 0.1,
        'reg_lambda'       : 0.1,
        'n_jobs'           : -1,
    }

Block 10 — Model Training Per Cluster Per Horizon


python
# ─────────────────────────────────────────────
# BLOCK 10: Training Loop
# One LightGBM per (cluster, anchor_horizon)
# CONFIG['n_clusters'] × len(anchor_horizons) models total
# = 10 × 9 = 90 models for default config
# ─────────────────────────────────────────────

def train_cluster_horizon_model(
    df: pd.DataFrame,
    cluster_id: int,
    horizon: int,
    splits: list,
    best_params: dict,
) -> tuple:
    """
    Train final production model on FULL training data (all folds merged)
    using the tuned hyperparameters.
    Returns (model, feature_importance_df)
    """
    target_col = f'target_h{horizon}'
    cluster_df = df[df['behavior_cluster'] == cluster_id].copy()

    # Use everything except the final val window as training data
    _, _, val_idx = splits[-1]
    val_dates = df.loc[val_idx, CONFIG['date_col']].unique()
    train_df  = cluster_df[~cluster_df[CONFIG['date_col']].isin(val_dates)]
    train_df  = train_df.dropna(subset=[target_col] + FEATURE_COLS)

    if len(train_df) < 50:
        logger.warning(f"  Cluster {cluster_id} h{horizon}: too few rows ({len(train_df)}) — skipping")
        return None, None

    X_train = train_df[FEATURE_COLS]
    y_train = train_df[target_col]

    dtrain = lgb.Dataset(
        X_train, label=y_train,
        categorical_feature=CATEGORICAL_COLS,
        free_raw_data=False
    )

    # Switch to DART for final production model (more accurate, slower)
    prod_params = {**best_params, 'boosting_type': 'dart', 'verbosity': -1}

    model = lgb.train(
        prod_params,
        dtrain,
        num_boost_round=CONFIG['retrain_n_rounds'],
        callbacks=[lgb.log_evaluation(0)]
    )

    importance = pd.DataFrame({
        'feature'   : FEATURE_COLS,
        'importance': model.feature_importance(importance_type='gain'),
    }).sort_values('importance', ascending=False)

    return model, importance


def train_all_models(
    df: pd.DataFrame,
    splits: list,
    param_registry: dict = None,   # if None, run tuning
) -> dict:
    """
    Master training loop.
    Returns model_registry: {(cluster_id, horizon): lgb.Booster}
    """
    model_registry = {}
    param_registry = param_registry or {}

    clusters  = sorted(df['behavior_cluster'].unique())
    horizons  = CONFIG['anchor_horizons']

    logger.info(f"Training {len(clusters)} clusters × {len(horizons)} horizons "
                f"= {len(clusters)*len(horizons)} models")

    for cluster_id in clusters:
        cluster_df = df[df['behavior_cluster'] == cluster_id]
        logger.info(f"\nCluster {cluster_id} — {len(cluster_df[CONFIG['account_col']].unique()):,} accounts")

        for horizon in horizons:
            key = (cluster_id, horizon)

            # ── Tune if no params cached ───────────────────────────────────────
            if key not in param_registry:
                logger.info(f"  Tuning h{horizon}...")
                params = tune_hyperparameters(df, horizon, cluster_id, splits)
                param_registry[key] = params
            else:
                params = param_registry[key]

            # ── Train final model ──────────────────────────────────────────────
            model, importance = train_cluster_horizon_model(
                df, cluster_id, horizon, splits, params
            )

            if model is not None:
                model_registry[key] = model
                # Save to disk
                model_path = f"{CONFIG['model_dir']}/lgbm_cluster{cluster_id}_h{horizon}.pkl"
                with open(model_path, 'wb') as f:
                    pickle.dump(model, f)

    logger.info(f"\nTotal models trained: {len(model_registry)}")
    return model_registry, param_registry

Block 11 — Walk-Forward Validation & MAPE Reporting


python
# ─────────────────────────────────────────────
# BLOCK 11: Walk-Forward Validation
# ─────────────────────────────────────────────

def mape(y_true, y_pred, eps=1.0):
    """MAPE, floored at eps to avoid div-by-zero on near-zero balances."""
    y_true, y_pred = np.array(y_true), np.array(y_pred)
    denom = np.maximum(np.abs(y_true), eps)
    return np.mean(np.abs(y_true - y_pred) / denom) * 100


def wape(y_true, y_pred):
    """Weighted APE — weighted by balance size. More business-meaningful."""
    return np.sum(np.abs(y_true - y_pred)) / (np.sum(np.abs(y_true)) + 1e-10) * 100


def evaluate_walk_forward(
    df: pd.DataFrame,
    model_registry: dict,
    splits: list,
) -> pd.DataFrame:
    """
    Evaluate all models across all CV folds.
    Returns DataFrame: fold × cluster × horizon → MAPE, WAPE, bias.
    """
    results = []

    for fold_num, train_idx, val_idx in splits:
        val_df = df.loc[val_idx].copy()

        for (cluster_id, horizon), model in model_registry.items():
            target_col = f'target_h{horizon}'
            cluster_val = val_df[val_df['behavior_cluster'] == cluster_id]
            cluster_val = cluster_val.dropna(subset=[target_col] + FEATURE_COLS)

            if len(cluster_val) < 5:
                continue

            X_val = cluster_val[FEATURE_COLS]
            y_true = cluster_val[target_col].values
            y_pred = model.predict(X_val)

            bias = np.mean(y_pred - y_true)   # positive = over-forecast

            results.append({
                'fold'       : fold_num,
                'cluster'    : cluster_id,
                'horizon'    : horizon,
                'n_rows'     : len(cluster_val),
                'mape'       : mape(y_true, y_pred),
                'wape'       : wape(y_true, y_pred),
                'bias'       : bias,
                'bias_pct'   : bias / (np.mean(np.abs(y_true)) + 1) * 100,
            })

    results_df = pd.DataFrame(results)

    # ── Summary by horizon ─────────────────────────────────────────────────────
    logger.info("\n── MAPE by Horizon (avg across clusters & folds) ──")
    by_horizon = results_df.groupby('horizon')[['mape', 'wape', 'bias_pct']].mean()
    logger.info(f"\n{by_horizon.round(2).to_string()}")

    # ── Check degradation curve ────────────────────────────────────────────────
    mape_h1  = by_horizon.loc[1, 'mape']  if 1  in by_horizon.index else np.nan
    mape_h90 = by_horizon.loc[90, 'mape'] if 90 in by_horizon.index else np.nan
    logger.info(f"\nMAPE degradation h1→h90: {mape_h1:.2f}% → {mape_h90:.2f}%")

    return results_df

