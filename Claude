def validate_and_clean(df: pd.DataFrame) -> pd.DataFrame:
    """
    Validate schema, coerce types, fill date gaps, clip negatives.
    Renames Redshift columns → internal standard names.
    """
    col = CONFIG

    # ── Rename to internal standard ───────────────────────────────────────────
    rename_map = {
        col['col_date']     : 'date',
        col['col_account']  : 'account_id',
        col['col_customer'] : 'customer_id',
        col['col_product']  : 'product_type',
        col['col_balance']  : 'balance',
    }
    df = df.rename(columns=rename_map)

    required = ['date', 'account_id', 'customer_id', 'product_type', 'balance']
    missing  = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"Missing columns after rename: {missing}. Got: {list(df.columns)}")

    # ── Type coercion ──────────────────────────────────────────────────────────
    df['date']        = pd.to_datetime(df['date'])
    df['balance']     = pd.to_numeric(df['balance'], errors='coerce').astype(float)
    df['account_id']  = df['account_id'].astype(str).str.strip()
    df['customer_id'] = df['customer_id'].astype(str).str.strip()

    # ── Filter to MMA ──────────────────────────────────────────────────────────
    before = len(df)
    df = df[df['product_type'] == CONFIG['product_filter']].copy()
    logger.info(
        f"MMA filter: {before:,} → {len(df):,} rows | "
        f"{df['account_id'].nunique():,} accounts | "
        f"date range: {df['date'].min().date()} → {df['date'].max().date()}"
    )

    # ── Deduplicate ────────────────────────────────────────────────────────────
    dupes = df.duplicated(subset=['date', 'account_id']).sum()
    if dupes > 0:
        logger.warning(f"{dupes:,} duplicate (date, account_id) rows — keeping last")
        df = df.drop_duplicates(subset=['date', 'account_id'], keep='last')

    # ── Contiguous daily index — fill gaps with forward-fill ──────────────────
    df = df.set_index(['account_id', 'date'])
    full_idx = pd.MultiIndex.from_product(
        [
            df.index.get_level_values(0).unique(),
            pd.date_range(df.index.get_level_values(1).min(),
                          df.index.get_level_values(1).max(), freq='D'),
        ],
        names=['account_id', 'date'],
    )
    df = df.reindex(full_idx)
    df['balance'] = df['balance'].groupby(level=0).transform(
        lambda s: s.ffill().bfill()
    )
    for c in ['customer_id', 'product_type']:
        if c in df.columns:
            df[c] = df[c].groupby(level=0).transform(lambda s: s.ffill().bfill())

    df = df.reset_index()

    # ── Negative balance clip ──────────────────────────────────────────────────
    neg = (df['balance'] < 0).sum()
    if neg:
        logger.warning(f"{neg:,} negative balance rows — clipping to 0")
        df['balance'] = df['balance'].clip(lower=0)

    nan_rows = df['balance'].isna().sum()
    if nan_rows:
        logger.warning(f"{nan_rows:,} NaN balance rows dropped")
        df = df.dropna(subset=['balance'])

    logger.info(f"Clean shape: {df.shape}")
    return df.sort_values(['account_id', 'date']).reset_index(drop=True)


# =============================================================================
# SECTION 5 — OUTLIER HANDLING
# =============================================================================

def flag_and_clip_outliers(df: pd.DataFrame, sigma: float = 4.0) -> pd.DataFrame:
    """
    Per-account outlier detection on daily balance CHANGE.
    MMA has fat tails — large rate-driven inflows/outflows.
    Clips at ±sigma std, adds binary is_outlier_day feature.
    """
    df = df.sort_values(['account_id', 'date']).copy()

    df['balance_change_1d'] = df.groupby('account_id')['balance'].diff()

    stats = (
        df.groupby('account_id')['balance_change_1d']
        .agg(['mean', 'std'])
        .rename(columns={'mean': '_chg_mean', 'std': '_chg_std'})
        .reset_index()
    )
    df = df.merge(stats, on='account_id', how='left')

    upper = df['_chg_mean'] + sigma * df['_chg_std']
    lower = df['_chg_mean'] - sigma * df['_chg_std']

    df['is_outlier_day'] = (
        (df['balance_change_1d'] > upper) | (df['balance_change_1d'] < lower)
    ).astype(int)

    df = df.drop(columns=['_chg_mean', '_chg_std'])

    logger.info(
        f"Outliers flagged: {df['is_outlier_day'].sum():,} rows "
        f"({df['is_outlier_day'].mean()*100:.2f}%)"
    )
    return df


