def build_lag_rolling_features(df: pd.DataFrame) -> pd.DataFrame:
    df = df.sort_values(['account_id', 'date']).copy()
    grp = df.groupby('account_id')['balance']

    for lag in [1, 7, 14, 30, 60, 90]:
        df[f'lag_{lag}'] = grp.shift(lag)

    for w in [7, 30, 90]:
        shifted = grp.shift(1)
        df[f'roll_mean_{w}'] = shifted.transform(lambda s: s.rolling(w, min_periods=1).mean())
        df[f'roll_std_{w}']  = shifted.transform(lambda s: s.rolling(w, min_periods=1).std().fillna(0))

    for w in [30, 90]:
        shifted = grp.shift(1)
        df[f'roll_min_{w}'] = shifted.transform(lambda s: s.rolling(w, min_periods=1).min())
        df[f'roll_max_{w}'] = shifted.transform(lambda s: s.rolling(w, min_periods=1).max())

    df['chg_1d']         = grp.diff(1)
    df['chg_7d']         = grp.diff(7)
    df['chg_30d']        = grp.diff(30)
    df['pct_chg_30d']    = grp.pct_change(30).replace([np.inf, -np.inf], np.nan)
    df['bal_vs_90d_avg'] = df['balance'] - df['roll_mean_90']

    return df


def build_calendar_features(df: pd.DataFrame) -> pd.DataFrame:
    d = df['date']
    df['day_of_week']          = d.dt.dayofweek
    df['day_of_month']         = d.dt.day
    df['day_of_year']          = d.dt.dayofyear
    df['week_of_year']         = d.dt.isocalendar().week.astype(int)
    df['month']                = d.dt.month
    df['quarter']              = d.dt.quarter
    df['is_month_start']       = (d.dt.day <= 3).astype(int)
    df['is_month_end']         = (d.dt.day >= d.dt.days_in_month - 2).astype(int)
    df['is_quarter_end']       = (d.dt.month.isin([3,6,9,12]) & (d.dt.day >= 28)).astype(int)
    df['is_year_end']          = ((d.dt.month == 12) & (d.dt.day >= 28)).astype(int)
    df['is_weekend']           = (d.dt.dayofweek >= 5).astype(int)
    df['is_holiday']           = d.isin(US_HOLIDAYS).astype(int)
    df['days_to_month_end']    = d.dt.days_in_month - d.dt.day
    df['days_since_month_start'] = d.dt.day - 1
    return df


def assemble_all_features(
    df             : pd.DataFrame,
    prophet_features : pd.DataFrame,
    account_summary  : pd.DataFrame,
) -> pd.DataFrame:
    """
    Joins all feature blocks into the final model-ready DataFrame.
    """
    df = build_lag_rolling_features(df)
    df = build_calendar_features(df)

    # ── Prophet features (one row per account → broadcast to all dates) ────────
    df = df.merge(
        prophet_features[[
            'account_id', 'slope_14d_norm', 'slope_30d_norm', 'slope_90d_norm',
            'slope_acceleration', 'prophet_uncertainty_pct',
            'seasonal_at_h30', 'seasonal_at_h60', 'seasonal_at_h90',
            'prophet_trend_at_h90',
        ]],
        on='account_id', how='left'
    )

    # ── Account summary + segment ──────────────────────────────────────────────
    df = df.merge(
        account_summary[[
            'account_id', 'avg_balance', 'std_balance', 'cv_balance',
            'account_tenure_days', 'segment_id',
        ]],
        on='account_id', how='left'
    )

    logger.info(f"Feature matrix shape: {df.shape}")
    return df


# =============================================================================
# SECTION 10 — STACKED TRAINING SET CONSTRUCTION
# =============================================================================
# Instead of N target columns (one per horizon), we stack the DataFrame:
# each account x date row is repeated once per anchor horizon.
# A new column 'horizon' is added as a feature.
# The single target column 'target' = balance h days ahead for that row.
#
# ONE model, ONE pkl file, ONE tuning run.
#
# Example: account A on date D becomes 9 rows in training:
#   account_id  date    horizon  ...features...  target
#   A           D       1                        balance(D+1)
#   A           D       7                        balance(D+7)
#   A           D       14                       balance(D+14)
#   ...
#   A           D       90                       balance(D+90)
#
# The model learns: "given account features AND horizon=30,
# predict the balance." Horizon-specific behavior emerges through
# tree splits on the horizon feature — no separate models needed.
#
# Seg 0 (negative balance) excluded from training entirely.
# Handled separately at inference via flat forecast fallback.
# =============================================================================

# Add 'horizon' to feature columns for the single global model
FEATURE_COLS_WITH_HORIZON = FEATURE_COLS + ['horizon']
CATEGORICAL_COLS_WITH_HORIZON = CATEGORICAL_COLS + ['horizon']


def build_stacked_dataset(df: pd.DataFrame) -> pd.DataFrame:
    """
    Stack account x date rows across all anchor horizons.
    Adds 'horizon' as a feature and 'target' as the label.
    Seg 0 excluded. Rows where target is outside history are dropped.

    Memory note: stacked dataset is ~9x the base DataFrame.
    At 20K accounts x 730 days x 9 horizons = ~131M rows.
    LightGBM handles this fine on 32GB+ RAM. Use chunksize in
    Redshift pull if memory is constrained upstream.
    """
    df = df.sort_values(['account_id', 'date']).copy()
    df = df[df['segment_id'] != 0]    # exclude negative balance

    grp    = df.groupby('account_id')['balance']
    chunks = []

    for h in CONFIG['anchor_horizons']:
        tmp            = df.copy()
        tmp['horizon'] = h
        tmp['target']  = grp.shift(-h)
        tmp            = tmp.dropna(subset=['target'])
        chunks.append(tmp)

    stacked = pd.concat(chunks, ignore_index=True)

    logger.info(
        f"Stacked dataset: {len(stacked):,} rows | "
        f"{stacked['account_id'].nunique():,} accounts | "
        f"{len(CONFIG['anchor_horizons'])} horizons stacked | "
        f"avg rows/account: {len(stacked) / stacked['account_id'].nunique():,.0f}"
    )
    return stacked


# =============================================================================
# SECTION 11 — WALK-FORWARD CV SPLITS
# =============================================================================
# Splits operate on the BASE (unstacked) DataFrame by date.
# The stacked dataset is built inside training using only train-window rows.
# This ensures no future balance leaks into lag/rolling features.
# =============================================================================

def walk_forward_splits(df: pd.DataFrame) -> list:
    """
    Walk-forward splits on base (unstacked) DataFrame.
    Validation window = max_horizon (90 days).
    Returned indices reference the BASE df — stacking happens inside training.
    """
    dates   = np.sort(df['date'].unique())
    n       = len(dates)
    val_win = CONFIG['val_window_days']
    n_folds = CONFIG['n_cv_folds']
    splits  = []
    val_end = n

    for fold in range(n_folds):
        val_start = val_end - val_win
        train_end = val_start

        if train_end < val_win * 2:
            logger.warning(f"Fold {fold+1}: insufficient training data — skipping")
            break

        train_dates = dates[:train_end]
        val_dates   = dates[val_start:val_end]

        train_idx = df[df['date'].isin(train_dates)].index
        val_idx   = df[df['date'].isin(val_dates)].index

        splits.append((fold + 1, train_idx, val_idx))
        logger.info(
            f"Fold {fold+1}: "
            f"train {dates[0]} to {dates[train_end-1]} | "
            f"val   {val_dates[0]} to {val_dates[-1]}"
        )
        val_end = val_start

    return splits[::-1]


# =============================================================================
# SECTION 12 — SAMPLE WEIGHTS
# =============================================================================
# Large-balance accounts drive portfolio liquidity impact.
# Weights ensure the single global model prioritizes MAPE accuracy
# where it matters most — high-value segments — without separate models.
# Seg 0 weight = 0.0 (excluded; handled by flat fallback at inference).
# HOW TO UPDATE: edit SEGMENT_WEIGHTS dict only.
# =============================================================================

SEGMENT_WEIGHTS = {
    0 : 0.0,    # negative   — excluded entirely
    1 : 0.3,    # micro      0-10K      (high count, low $ impact)
    2 : 0.5,    # small      10K-25K
    3 : 1.0,    # mid        25K-125K   (baseline)
    4 : 2.5,    # upper_mid  125K-250K  (volatile + high count per ED&A)
    5 : 2.5,    # upper_mid  250K-500K  (transitioning)
    6 : 3.5,    # high       500K-1M
    7 : 4.5,    # very_high  1M-5M      (high count + high value per ED&A)
    8 : 5.0,    # ultra      5M+        (maximum weight)
}

SEG4_SPLIT_THRESHOLD_PP = 3.0    # pp gap vs neighbors triggers split warning


def build_sample_weights(df: pd.DataFrame) -> pd.Series:
    """Map segment_id to sample weight for each training row."""
    return df['segment_id'].map(SEGMENT_WEIGHTS).fillna(1.0)


# =============================================================================
# SECTION 13 — HYPERPARAMETER TUNING (OPTUNA)
# =============================================================================
# ONE tuning run — on the stacked dataset (all horizons, all segments).
# 10% account sample x latest fold only for speed.
# Pruner kills bad trials early.
# Result: one param dict, cached as param_registry on disk.
# =============================================================================

def _default_lgbm_params() -> dict:
    return {
        'objective'         : CONFIG['lgbm_objective'],
        'metric'            : CONFIG['lgbm_objective'],
        'verbosity'         : -1,
        'num_leaves'        : 63,
        'learning_rate'     : 0.05,
        'min_child_samples' : 50,
        'feature_fraction'  : 0.8,
        'bagging_fraction'  : 0.8,
        'bagging_freq'      : 5,
        'reg_alpha'         : 0.1,
        'reg_lambda'        : 0.1,
        'n_jobs'            : -1,
    }


def tune_lgbm_single(
    df     : pd.DataFrame,    # BASE (unstacked) DataFrame
    splits : list,
) -> dict:
    """
    Single Optuna tuning run across all horizons and segments.
    Builds stacked sample internally from 10% of accounts.
    Uses latest CV fold only for speed.
    Sample weights applied — large-balance segments drive the loss.
    """
    # 10% account sample — stratified across segments
    sampled_accounts = (
        df[df['segment_id'] != 0]['account_id']
        .drop_duplicates()
        .sample(frac=CONFIG['tune_sample_frac'], random_state=42)
    )
    df_s = df[df['account_id'].isin(sampled_accounts)]

    # Use latest fold date boundaries
    _, train_idx, val_idx = splits[-1]
    train_dates = df.loc[train_idx, 'date'].unique()
    val_dates   = df.loc[val_idx,   'date'].unique()

    train_base = df_s[df_s['date'].isin(train_dates)]
    val_base   = df_s[df_s['date'].isin(val_dates)]

    # Stack both splits across horizons
    train_stacked = build_stacked_dataset(train_base)
    val_stacked   = build_stacked_dataset(val_base)

    train_stacked = train_stacked.dropna(subset=FEATURE_COLS_WITH_HORIZON + ['target'])
    val_stacked   = val_stacked.dropna(subset=FEATURE_COLS_WITH_HORIZON + ['target'])

    if len(train_stacked) < 100 or len(val_stacked) < 10:
        logger.warning("Insufficient rows for tuning — using default params")
        return _default_lgbm_params()

    train_weights = build_sample_weights(train_stacked)

    dtrain = lgb.Dataset(
        train_stacked[FEATURE_COLS_WITH_HORIZON],
        label=train_stacked['target'],
        weight=train_weights,
        categorical_feature=CATEGORICAL_COLS_WITH_HORIZON,
        free_raw_data=False,
    )
    dval = lgb.Dataset(
        val_stacked[FEATURE_COLS_WITH_HORIZON],
        label=val_stacked['target'],
        reference=dtrain,
        categorical_feature=CATEGORICAL_COLS_WITH_HORIZON,
        free_raw_data=False,
    )

    def objective(trial):
        params = {
            'objective'         : CONFIG['lgbm_objective'],
            'metric'            : CONFIG['lgbm_objective'],
            'verbosity'         : -1,
            'boosting_type'     : 'gbdt',    # GBDT during tuning — fast
            'num_leaves'        : trial.suggest_int('num_leaves', 31, 256),
            'learning_rate'     : trial.suggest_float('learning_rate', 0.01, 0.3, log=True),
            'min_child_samples' : trial.suggest_int('min_child_samples', 20, 200),
            'feature_fraction'  : trial.suggest_float('feature_fraction', 0.5, 1.0),
            'bagging_fraction'  : trial.suggest_float('bagging_fraction', 0.6, 1.0),
            'bagging_freq'      : trial.suggest_int('bagging_freq', 1, 7),
            'reg_alpha'         : trial.suggest_float('reg_alpha', 1e-8, 10.0, log=True),
            'reg_lambda'        : trial.suggest_float('reg_lambda', 1e-8, 10.0, log=True),
            'n_jobs'            : -1,
        }
        cb = LightGBMPruningCallback(trial, 'valid mape')
        model = lgb.train(
            params, dtrain,
            valid_sets=[dval],
            num_boost_round=500,
            callbacks=[
                cb,
                lgb.early_stopping(CONFIG['early_stopping_rounds'], verbose=False),
                lgb.log_evaluation(0),
            ]
        )
        return model.best_score['valid mape']['mape']

    study = optuna.create_study(
        direction='minimize',
        pruner=optuna.pruners.MedianPruner(n_warmup_steps=10),
        sampler=optuna.samplers.TPESampler(seed=42),
    )
    study.optimize(
        objective,
        n_trials=CONFIG['tune_n_trials'],
        timeout=CONFIG['tune_timeout_sec'],
        show_progress_bar=False,
    )

    best = study.best_params
    best.update({
        'objective' : CONFIG['lgbm_objective'],
        'metric'    : CONFIG['lgbm_objective'],
        'verbosity' : -1,
        'n_jobs'    : -1,
    })
    logger.info(
        f"Tuning complete — best MAPE={study.best_value:.4f} | "
        f"trials={len(study.trials)}"
    )
    return best


# =============================================================================
# SECTION 14 — MODEL TRAINING
# =============================================================================
# ONE LightGBM trained on the full stacked dataset.
# ONE pkl file saved to disk.
# segment_id and horizon are both categorical features —
# the tree learns segment x horizon interaction natively.
# DART boosting for final production fit.
# =============================================================================

def train_single_model(
    df             : pd.DataFrame,    # BASE (unstacked) DataFrame
    splits         : list,
    params         : dict,
) -> lgb.Booster:
    """
    Train the single production LightGBM on the full stacked dataset.
    Excludes last validation window dates from training.
    Seg 0 excluded. Sample weights applied.
    DART boosting — more accurate than GBDT, used at final fit only.
    """
    # Exclude last val window
    _, _, val_idx = splits[-1]
    val_dates = df.loc[val_idx, 'date'].unique()
    train_base = df[~df['date'].isin(val_dates)]

    # Build full stacked training set
    train_stacked = build_stacked_dataset(train_base)
    train_stacked = train_stacked.dropna(subset=FEATURE_COLS_WITH_HORIZON + ['target'])

    if len(train_stacked) < 50:
        raise RuntimeError(
            f"Insufficient training rows ({len(train_stacked)}) — check data pipeline"
        )

    train_weights = build_sample_weights(train_stacked)

    logger.info(
        f"Training single global model | "
        f"{len(train_stacked):,} stacked rows | "
        f"{train_stacked['account_id'].nunique():,} accounts | "
        f"horizons: {sorted(train_stacked['horizon'].unique().tolist())} | "
        f"segments: {sorted(train_stacked['segment_id'].unique().tolist())}"
    )

    dtrain = lgb.Dataset(
        train_stacked[FEATURE_COLS_WITH_HORIZON],
        label=train_stacked['target'],
        weight=train_weights,
        categorical_feature=CATEGORICAL_COLS_WITH_HORIZON,
        free_raw_data=False,
    )

    prod_params = {
        **params,
        'boosting_type' : 'dart',    # DART for production — accurate, no overfitting
        'verbosity'     : -1,
    }

    model = lgb.train(
        prod_params,
        dtrain,
        num_boost_round=CONFIG['retrain_n_rounds'],
        callbacks=[lgb.log_evaluation(100)],
    )

    # Save single model to disk
    model_path = f"{CONFIG['model_dir']}/lgbm_global_single.pkl"
    with open(model_path, 'wb') as f:
        pickle.dump(model, f)
    logger.info(f"Single global model saved -> {model_path}")

    return model


def train_model(
    df             : pd.DataFrame,
    splits         : list,
    params         : dict = None,
) -> tuple:
    """
    Entry point for training.
    params=None  -> run Optuna tuning first (monthly)
    params=dict  -> use cached params, skip tuning (weekly)
    Returns (model, params).
    """
    if params is None:
        logger.info("Running Optuna tuning (single global run)...")
        params = tune_lgbm_single(df, splits)
    else:
        logger.info("Using cached params — skipping tuning")

    model = train_single_model(df, splits, params)
    return model, params


# =============================================================================
# SECTION 15 — WALK-FORWARD VALIDATION & METRICS
# =============================================================================
# Evaluates ONE model across all CV folds.
# Reports MAPE at three levels:
#   1. Overall by horizon  — primary headline metric
#   2. By segment          — diagnose where model struggles
#   3. Seg 4 divergence    — automated split recommendation trigger
# =============================================================================

def mape(y_true, y_pred, floor=1.0):
    y_true, y_pred = np.array(y_true), np.array(y_pred)
    denom = np.maximum(np.abs(y_true), floor)
    return np.mean(np.abs(y_true - y_pred) / denom) * 100


def wape(y_true, y_pred):
    return np.sum(np.abs(y_true - y_pred)) / (np.sum(np.abs(y_true)) + 1e-10) * 100


def evaluate_walk_forward(
    df    : pd.DataFrame,    # BASE (unstacked) DataFrame
    model : lgb.Booster,
    splits: list,
) -> pd.DataFrame:
    """
    Walk-forward evaluation of single global model.
    Builds stacked val set per fold, scores with model,
    reports MAPE by horizon and by segment.
    Seg 0 excluded from all metrics.
    """
    results = []

    for fold_num, train_idx, val_idx in splits:
        val_base    = df.loc[val_idx].copy()
        val_stacked = build_stacked_dataset(val_base)
        val_stacked = val_stacked.dropna(subset=FEATURE_COLS_WITH_HORIZON + ['target'])

        if len(val_stacked) < 5:
            continue

        y_true = val_stacked['target'].values
        y_pred = model.predict(val_stacked[FEATURE_COLS_WITH_HORIZON])

        # Overall for this fold
        results.append({
            'fold'     : fold_num,
            'segment'  : 'ALL',
            'horizon'  : 'ALL',
            'n_rows'   : len(val_stacked),
            'mape'     : mape(y_true, y_pred),
            'wape'     : wape(y_true, y_pred),
            'bias_pct' : np.mean(y_pred - y_true) / (np.mean(np.abs(y_true)) + 1) * 100,
        })

        # By horizon
        for h in sorted(val_stacked['horizon'].unique()):
            mask = val_stacked['horizon'] == h
            yt, yp = y_true[mask], y_pred[mask]
            if len(yt) < 5:
                continue
            results.append({
                'fold'     : fold_num,
                'segment'  : 'ALL',
                'horizon'  : h,
                'n_rows'   : len(yt),
                'mape'     : mape(yt, yp),
                'wape'     : wape(yt, yp),
                'bias_pct' : np.mean(yp - yt) / (np.mean(np.abs(yt)) + 1) * 100,
            })

        # By segment
        for seg_id in sorted(val_stacked['segment_id'].unique()):
            mask = val_stacked['segment_id'] == seg_id
            yt, yp = y_true[mask], y_pred[mask]
            if len(yt) < 5:
                continue
            results.append({
                'fold'     : fold_num,
                'segment'  : seg_id,
                'horizon'  : 'ALL',
                'n_rows'   : len(yt),
                'mape'     : mape(yt, yp),
                'wape'     : wape(yt, yp),
                'bias_pct' : np.mean(yp - yt) / (np.mean(np.abs(yt)) + 1) * 100,
            })

    results_df = pd.DataFrame(results)

    # Overall by horizon
    logger.info("\n-- MAPE by Horizon (single global model, avg across folds) --")
    by_h = (
        results_df[(results_df['segment'] == 'ALL') & (results_df['horizon'] != 'ALL')]
        .groupby('horizon')[['mape', 'wape', 'bias_pct']].mean()
    )
    logger.info(f"\n{by_h.round(2).to_string()}")

    overall = results_df[
        (results_df['segment'] == 'ALL') & (results_df['horizon'] == 'ALL')
    ]['mape'].mean()
    logger.info(f"\nOverall MAPE (all horizons, all segments): {overall:.2f}%")

    h_vals = by_h.index.tolist()
    if len(h_vals) >= 2:
        logger.info(
            f"MAPE degradation h{h_vals[0]} -> h{h_vals[-1]}: "
            f"{by_h['mape'].iloc[0]:.2f}% -> {by_h['mape'].iloc[-1]:.2f}%"
        )

    # By segment
    logger.info("\n-- MAPE by Segment (avg across horizons & folds) --")
    by_seg = (
        results_df[(results_df['segment'] != 'ALL') & (results_df['horizon'] == 'ALL')]
        .groupby('segment')[['mape', 'wape', 'bias_pct']].mean()
    )
    for sid, row in by_seg.iterrows():
        label    = SEGMENT_LABELS.get(sid, '?')
        vol_flag = ' WARNING HIGH VOLATILITY' if sid in HIGH_VOLATILITY_SEGMENTS else ''
        watch    = ' WATCH'                   if sid in WATCH_SEGMENTS           else ''
        logger.info(
            f"  Seg {sid} ({label:25s}): "
            f"MAPE={row['mape']:5.2f}% | WAPE={row['wape']:5.2f}% | "
            f"bias={row['bias_pct']:+.2f}%{vol_flag}{watch}"
        )

    # Seg 4 divergence check
    if all(s in by_seg.index for s in [3, 4, 5]):
        seg4_mape    = by_seg.loc[4, 'mape']
        neighbor_avg = (by_seg.loc[3, 'mape'] + by_seg.loc[5, 'mape']) / 2
        gap          = seg4_mape - neighbor_avg
        if gap > SEG4_SPLIT_THRESHOLD_PP:
            logger.warning(
                f"\nSEG 4 SPLIT RECOMMENDATION: "
                f"Seg 4 (upper_mid_125k_250k) MAPE={seg4_mape:.2f}% is "
                f"{gap:.1f}pp above neighbor avg ({neighbor_avg:.2f}%). "
                f"Consider giving Seg 4 its own model."
            )
        else:
            logger.info(
                f"\nSeg 4 divergence check passed: gap={gap:.1f}pp "
                f"(threshold={SEG4_SPLIT_THRESHOLD_PP}pp)"
            )

    # MAPE alert threshold
    mape_alert = 10.0
    for sid in WATCH_SEGMENTS:
        if sid in by_seg.index and by_seg.loc[sid, 'mape'] > mape_alert:
            logger.warning(
                f"Seg {sid} ({SEGMENT_LABELS.get(sid,'?')}) "
                f"MAPE={by_seg.loc[sid,'mape']:.2f}% > {mape_alert}% threshold"
            )

    results_df.to_parquet(f"{CONFIG['model_dir']}/eval_results.parquet", index=False)
    return results_df


# =============================================================================
# SECTION 16 — INFERENCE: 90-DAY DAILY FORECAST
# =============================================================================
# Single model scored once per account per anchor horizon.
# horizon passed as a feature column — same model, different horizon value.
# Seg 0 accounts get flat forecast (current balance held constant).
# Cubic spline interpolation between anchors -> smooth daily curve.
# =============================================================================

def generate_forecast(
    df         : pd.DataFrame,    # BASE (unstacked) feature DataFrame
    model      : lgb.Booster,
    as_of_date : str,
) -> tuple:
    """
    Generate 90-day daily balance forecast for all MMA accounts.

    For each account:
        1. Snapshot features as of as_of_date
        2. Score single model at each anchor horizon by setting horizon feature
        3. Cubic spline interpolation -> daily curve for days 1-90
        4. Hard floor at 0

    Seg 0 accounts: flat forecast = current balance (conservative fallback).

    Returns:
        forecast_df  -- one row per (account_id, forecast_date)
        portfolio_df -- daily portfolio total MMA balance
    """
    as_of = pd.to_datetime(as_of_date)
    snap  = df[df['date'] == as_of].copy()

    if len(snap) == 0:
        raise ValueError(f"No rows found for as_of_date={as_of_date}")

    logger.info(f"Forecasting {len(snap):,} MMA accounts as of {as_of.date()}")

    seg0_count = (snap['segment_id'] == 0).sum()
    if seg0_count > 0:
        logger.warning(
            f"  {seg0_count:,} seg-0 (negative balance) accounts -> "
            f"flat forecast fallback"
        )

    # Non-seg-0 accounts: score model at each anchor horizon
    valid_snap   = snap[snap['segment_id'] != 0].dropna(subset=FEATURE_COLS)
    anchor_preds = {acct: {} for acct in valid_snap['account_id'].values}

    for h in CONFIG['anchor_horizons']:
        score_df           = valid_snap.copy()
        score_df['horizon'] = h
        preds = np.maximum(
            model.predict(score_df[FEATURE_COLS_WITH_HORIZON]), 0
        )
        for acct, pred in zip(score_df['account_id'].values, preds):
            anchor_preds[acct][h] = pred

    # Seg 0 flat forecasts
    for _, row in snap[snap['segment_id'] == 0].iterrows():
        acct = row['account_id']
        bal  = float(row['balance'])
        anchor_preds[acct] = {h: bal for h in CONFIG['anchor_horizons']}

    # Cubic spline interpolation -> daily for days 1-90
    forecast_rows = []
    anchors       = CONFIG['anchor_horizons']

    for acct, preds_by_h in anchor_preds.items():
        row         = snap[snap['account_id'] == acct].iloc[0]
        customer_id = row['customer_id']
        current_bal = float(row['balance'])
        seg_id      = int(row['segment_id'])

        h_pts = [0] + [h for h in anchors if h in preds_by_h]
        y_pts = [current_bal] + [preds_by_h[h] for h in anchors if h in preds_by_h]

        if len(h_pts) < 3:
            continue

        interp_fn = interp1d(h_pts, y_pts, kind='cubic', fill_value='extrapolate')

        for day in range(1, CONFIG['max_horizon'] + 1):
            forecast_rows.append({
                'account_id'      : acct,
                'customer_id'     : customer_id,
                'segment_id'      : seg_id,
                'segment_label'   : SEGMENT_LABELS.get(seg_id, '?'),
                'as_of_date'      : as_of.date(),
                'forecast_date'   : (as_of + pd.Timedelta(days=day)).date(),
                'days_ahead'      : day,
                'balance_forecast': round(float(np.maximum(interp_fn(day), 0)), 2),
            })

    forecast_df = pd.DataFrame(forecast_rows)
    logger.info(f"Forecast rows generated: {len(forecast_df):,}")

    # Portfolio summary
    portfolio_df = (
        forecast_df.groupby('days_ahead')['balance_forecast']
        .sum().reset_index()
        .rename(columns={'balance_forecast': 'portfolio_mma_total'})
    )

    logger.info(f"\nPortfolio MMA (as of {as_of.date()}):")
    for d in [1, 30, 60, 90]:
        row = portfolio_df[portfolio_df['days_ahead'] == d]
        if len(row):
            logger.info(f"  Day {d:3d}: ${row['portfolio_mma_total'].values[0]:,.0f}")

    # Segment breakdown at day 90
    logger.info("\nPortfolio breakdown by segment (day 90):")
    seg_breakdown = (
        forecast_df[forecast_df['days_ahead'] == 90]
        .groupby(['segment_id', 'segment_label'])['balance_forecast']
        .sum().reset_index().sort_values('segment_id')
    )
    for _, row in seg_breakdown.iterrows():
        logger.info(
            f"  Seg {int(row['segment_id'])} "
            f"({row['segment_label']:25s}): "
            f"${row['balance_forecast']:>15,.0f}"
        )

    return forecast_df, portfolio_df


# =============================================================================
# SECTION 17 — MASTER PIPELINE ORCHESTRATOR
# =============================================================================

def run_pipeline(
    as_of_date     : str,
    mma_query      : str  = None,
    all_prod_query : str  = None,
    cached_params  : dict = None,    # None = retune (monthly); dict = skip tuning (weekly)
    n_workers      : int  = None,
    chunksize      : int  = None,
) -> dict:
    """
    Full MMA forecasting pipeline — single LightGBM model.

    Weekly run  : pass cached_params (loaded from disk) -> skips Optuna
    Monthly run : pass cached_params=None               -> reruns Optuna

    Returns dict with keys:
        model, params, forecast_df, portfolio_df, eval_df
    """
    n_workers = n_workers or CONFIG['n_workers']

    logger.info("=" * 65)
    logger.info("MMA FORECAST PIPELINE START  |  1 LightGBM + Prophet")
    logger.info(f"as_of_date={as_of_date} | n_workers={n_workers}")
    logger.info("=" * 65)

    # STAGE 1: Pull MMA data
    logger.info("\nSTAGE 1: Redshift pull -- MMA daily balances")
    mma_raw = pull_from_redshift(
        query      = mma_query or REDSHIFT_QUERIES['mma_daily'],
        query_name = 'mma_daily',
        chunksize  = chunksize,
    )

    # STAGE 2: Pull all products (cross-product features)
    logger.info("\nSTAGE 2: Redshift pull -- all products")
    all_raw = pull_from_redshift(
        query      = all_prod_query or REDSHIFT_QUERIES['all_products_daily'],
        query_name = 'all_products_daily',
        chunksize  = chunksize,
    )

    # STAGE 3: Validate & clean
    logger.info("\nSTAGE 3: Validate & clean")
    mma_df = validate_and_clean(mma_raw)

    # STAGE 4: Outlier handling
    logger.info("\nSTAGE 4: Outlier detection & clipping")
    mma_df = flag_and_clip_outliers(mma_df)

    # STAGE 5: Account summary + segmentation
    logger.info("\nSTAGE 5: Account summary & rule-based segmentation")
    acct_summary = build_account_summary(mma_df)
    mma_df = mma_df.merge(
        acct_summary[['account_id', 'avg_balance', 'std_balance',
                      'cv_balance', 'account_tenure_days', 'segment_id']],
        on='account_id', how='left'
    )

    # STAGE 6: Cross-product customer features
    logger.info("\nSTAGE 6: Cross-product customer features")
    mma_df = build_cross_product_features(all_raw, mma_df)

    # STAGE 7: Prophet (parallelized)
    logger.info("\nSTAGE 7: FB Prophet -- trend features (parallelized)")
    prophet_features = run_prophet_parallel(mma_df, n_workers=n_workers)
    prophet_features.to_parquet(
        f"{CONFIG['model_dir']}/prophet_features.parquet", index=False
    )

    # STAGE 8: Feature assembly
    logger.info("\nSTAGE 8: Feature assembly")
    mma_df = assemble_all_features(mma_df, prophet_features, acct_summary)

    # STAGE 9: Walk-forward CV splits (on base df)
    logger.info("\nSTAGE 9: Walk-forward CV splits")
    splits = walk_forward_splits(mma_df)

    # STAGE 10: Train single model
    # (stacked dataset built internally — no separate build_targets call needed)
    run_type = "WEEKLY (cached params)" if cached_params else "MONTHLY (full Optuna tuning)"
    logger.info(f"\nSTAGE 10: Training single global LightGBM | {run_type}")
    model, params = train_model(mma_df, splits, params=cached_params)

    # Save params
    params_path = f"{CONFIG['model_dir']}/params.pkl"
    with open(params_path, 'wb') as f:
        pickle.dump(params, f)
    logger.info(f"Params saved -> {params_path}")

    # STAGE 11: Walk-forward validation
    logger.info("\nSTAGE 11: Walk-forward validation")
    eval_df = evaluate_walk_forward(mma_df, model, splits)

    # STAGE 12: Generate forecasts
    logger.info("\nSTAGE 12: Generating 90-day daily forecasts")
    forecast_df, portfolio_df = generate_forecast(mma_df, model, as_of_date)

    forecast_df.to_parquet(
        f"{CONFIG['forecast_dir']}/mma_forecast_{as_of_date}.parquet", index=False
    )
    portfolio_df.to_parquet(
        f"{CONFIG['forecast_dir']}/mma_portfolio_{as_of_date}.parquet", index=False
    )

    logger.info("\n" + "=" * 65)
    logger.info("MMA FORECAST PIPELINE COMPLETE")
    logger.info("Artifacts: 1 lgbm pkl + 1 params pkl + prophet_features parquet")
    logger.info("=" * 65)

    return {
        'model'        : model,
        'params'       : params,
        'forecast_df'  : forecast_df,
        'portfolio_df' : portfolio_df,
        'eval_df'      : eval_df,
    }


# =============================================================================
# SECTION 18 -- WEEKLY vs MONTHLY RUN HELPERS
# =============================================================================

def run_weekly(as_of_date: str, **kwargs) -> dict:
    """
    Weekly retrain -- loads cached params, skips Optuna tuning.
    Params path: models/mma/params.pkl
    """
    params_path = f"{CONFIG['model_dir']}/params.pkl"
    if os.path.exists(params_path):
        with open(params_path, 'rb') as f:
            cached_params = pickle.load(f)
        logger.info(f"Loaded cached params from {params_path} -- skipping tuning")
    else:
        logger.warning("No cached params found -- running full tuning (first run)")
        cached_params = None

    return run_pipeline(as_of_date=as_of_date, cached_params=cached_params, **kwargs)


def run_monthly(as_of_date: str, **kwargs) -> dict:
    """
    Monthly retune -- clears cached params, runs full Optuna tuning.
    Call on first Monday of each month.
    """
    logger.info("Monthly run -- Optuna tuning enabled (cached params cleared)")
    return run_pipeline(as_of_date=as_of_date, cached_params=None, **kwargs)


