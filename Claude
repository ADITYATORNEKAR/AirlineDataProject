def _validate_redshift_env():
    missing = [k for k, v in REDSHIFT_CONFIG.items()
               if v is None and k != 'connect_timeout']
    if missing:
        raise EnvironmentError(
            f"Missing Redshift env vars: {missing}\n"
            f"Set: REDSHIFT_HOST, REDSHIFT_PORT, REDSHIFT_DBNAME, "
            f"REDSHIFT_USER, REDSHIFT_PASSWORD"
        )


def pull_from_redshift(
    query      : str,
    query_name : str  = 'query',
    chunksize  : int  = None,
) -> pd.DataFrame:
    """
    Execute SQL against Redshift, return DataFrame.
    Uses psycopg2 directly (lighter than SQLAlchemy for bulk reads).
    Set chunksize (~500_000) for very large pulls.
    """
    _validate_redshift_env()

    try:
        import psycopg2
    except ImportError:
        raise ImportError("pip install psycopg2-binary")

    logger.info(f"Redshift pull: [{query_name}]")
    logger.info(f"Query: {query.strip()[:120]}...")

    conn = psycopg2.connect(**REDSHIFT_CONFIG)
    try:
        if chunksize:
            chunks = pd.read_sql_query(query, conn, chunksize=chunksize)
            df = pd.concat(chunks, ignore_index=True)
        else:
            df = pd.read_sql_query(query, conn)
    finally:
        conn.close()

    logger.info(f"  [{query_name}] → {len(df):,} rows | {df.shape[1]} cols")
    return df


def pull_custom_query(sql: str, chunksize: int = None) -> pd.DataFrame:
    """Pass any ad-hoc SQL directly. Your queries are ready? Drop them here."""
    return pull_from_redshift(sql, query_name='custom', chunksize=chunksize)


