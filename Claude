def build_cross_product_features(
    full_df  : pd.DataFrame,   # all products (CHK+MMA+SAV+CD), already cleaned
    mma_df   : pd.DataFrame,   # MMA only
) -> pd.DataFrame:
    """
    Customer-level balance aggregates across all products.
    Flows down to every MMA account row via customer_id + date join.
    All computed from historical data — zero leakage.
    """
    logger.info("Building cross-product customer features...")

    # Standardize full_df columns (same rename as validate_and_clean)
    rename_map = {
        CONFIG['col_date']     : 'date',
        CONFIG['col_account']  : 'account_id',
        CONFIG['col_customer'] : 'customer_id',
        CONFIG['col_product']  : 'product_type',
        CONFIG['col_balance']  : 'balance',
    }
    full_df = full_df.rename(columns={k: v for k, v in rename_map.items()
                                       if k in full_df.columns})
    full_df['date']    = pd.to_datetime(full_df['date'])
    full_df['balance'] = pd.to_numeric(full_df['balance'], errors='coerce').fillna(0)

    cust_daily = (
        full_df
        .groupby(['customer_id', 'date', 'product_type'])['balance']
        .sum()
        .unstack(fill_value=0)
        .reset_index()
    )

    for p in ['CHK', 'MMA', 'SAV', 'CD']:
        if p not in cust_daily.columns:
            cust_daily[p] = 0.0

    cust_daily['total_balance']  = cust_daily[['CHK', 'MMA', 'SAV', 'CD']].sum(axis=1)
    cust_daily['liquid_balance'] = cust_daily['CHK'] + cust_daily['SAV']
    cust_daily['mma_share']      = cust_daily['MMA'] / (cust_daily['total_balance'] + 1)
    cust_daily['liquid_ratio']   = cust_daily['liquid_balance'] / (cust_daily['total_balance'] + 1)
    cust_daily['num_products']   = (cust_daily[['CHK', 'MMA', 'SAV', 'CD']] > 0).sum(axis=1)

    cust_daily = cust_daily.sort_values(['customer_id', 'date'])
    cust_daily['cust_total_30d_net_flow'] = (
        cust_daily.groupby('customer_id')['total_balance'].transform(lambda s: s.diff(30))
    )
    cust_daily['cust_mma_30d_net_flow'] = (
        cust_daily.groupby('customer_id')['MMA'].transform(lambda s: s.diff(30))
    )

    keep = [
        'customer_id', 'date',
        'total_balance', 'liquid_balance', 'mma_share', 'liquid_ratio',
        'num_products', 'cust_total_30d_net_flow', 'cust_mma_30d_net_flow',
    ]
    mma_df = mma_df.merge(cust_daily[keep], on=['customer_id', 'date'], how='left')
    return mma_df


